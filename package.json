{
  "name": "mimir-workspace",
  "version": "0.4.0",
  "private": true,
  "description": "Source of truth for work state — tasks, the work hierarchy, and frozen artifacts. Local-first, agent-driven; SQLite is the substrate, markdown a projection.",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "mimir": "bun run packages/bin/src/main.ts",
    "check": "vp check",
    "test": "bun test",
    "verify": "bun run check && bun test",
    "build": "bun build packages/bin/src/main.ts --compile --outfile dist/mimir"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "1.67.0",
    "vite-plus": "0.1.24"
  }
}
